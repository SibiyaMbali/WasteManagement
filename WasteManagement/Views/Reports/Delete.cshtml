@model WasteManagement.Models.Report

<h1>Delete Report</h1>

<h3>Are you sure you want to delete this report?</h3>

<div>
    <hr />

    <dl class="row">

        <dt class="col-sm-2">
            Title
        </dt>

        <dd class="col-sm-10">
            @Model.Title
        </dd>

        <dt class="col-sm-2">
            Description
        </dt>

        <dd class="col-sm-10">
            @Model.Description
        </dd>

    </dl>

    <form asp-action="Delete">

        <input type="hidden" asp-for="ReportId" />

        <button type="submit" class="btn btn-danger">
            Delete
        </button>

        <a asp-action="Index" class="btn btn-secondary">
            Cancel
        </a>

    </form>
</div>
